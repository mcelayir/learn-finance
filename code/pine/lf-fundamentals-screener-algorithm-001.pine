//@version=6
indicator("LF Fundamentals Screener — Algorithm 001", shorttitle="LF MCSA Screener", overlay=false)

// This screener implements the 15 criteria defined in
// docs/finance/lf-fundementals-screener-algorithm-001-en.md.
//
// Usage:
// - For quick testing, fill the inputs below manually.
// - To integrate with TradingView fundamentals (when available), replace
//   the input values with calls to the platform's financial/fundamental
//   request functions and set the inputs to `na`.

// --- Inputs (quarterly / annual metrics) ---
string market_segment = input.string("YILDIZ", "Market Segment (e.g. YILDIZ)")

// Quarterly series (most recent quarter and previous quarter)
// (Leave at 0 when auto-fetch is enabled — manual values are only used when auto-fetch is OFF)
float roe_q           = input.float(0.0, "ROE (most recent quarter)")
float roe_q_prev      = input.float(0.0, "ROE (previous quarter)")

float netprofit_q     = input.float(0.0, "Net Profit (most recent quarter)")
float netprofit_q_prev= input.float(0.0, "Net Profit (previous quarter)")

float revenue_q       = input.float(0.0, "Revenue (most recent quarter)")
float revenue_q_prev  = input.float(0.0, "Revenue (previous quarter)")

float ebitda_q        = input.float(0.0, "EBITDA (most recent quarter)")
float ebitda_q_prev   = input.float(0.0, "EBITDA (previous quarter)")

float operprofit_q    = input.float(0.0, "Operating Profit (most recent quarter)")
float operprofit_q_prev = input.float(0.0, "Operating Profit (previous quarter)")

float eps_q           = input.float(0.0, "EPS (most recent quarter)")
float eps_q_prev      = input.float(0.0, "EPS (previous quarter)")

// Other fields
float free_float      = input.float(0.0, "Free Float Rate (0-1)")
float peg_ratio       = input.float(0.0, "PEG Ratio")
float earnings_growth = input.float(0.0, "Annual Earnings Growth Rate (%)")

float current_assets  = input.float(0.0, "Current Assets")
float current_liab    = input.float(0.0, "Current Liabilities")
float total_debt      = input.float(0.0, "Total Debt")
float cash_equiv      = input.float(0.0, "Cash & Cash Equivalents")
float inventory       = input.float(0.0, "Inventory")

// Operating cash flow (annual)
float opcf_current_y  = input.float(0.0, "Operating Cash Flow (current year)")
float opcf_prev_y     = input.float(0.0, "Operating Cash Flow (previous year)")

// Auto-fetch toggle: when true, try to pull values from TradingView's
// financials via `request.financial`. If a fetch returns `na`, the
// script falls back to the manual `input` values above.
// NOTE: auto_fetch has NO effect on Criterion 1 (Star Market segment).
// That check always relies on the manual `market_segment` input string.
bool auto_fetch = input.bool(true, "Auto-fetch fundamentals when available")

// --- Try fetching via request.financial() with reasonable field names ---
// Note: field availability and exact names vary by symbol and TV plan.
// We try common field keys and fall back to inputs if missing.
float f_roe_q            = auto_fetch ? request.financial(syminfo.tickerid, "return_on_equity", "FQ") : na
float roe_q_prev_fetched = ta.valuewhen(not na(f_roe_q) and not na(f_roe_q[1]) and f_roe_q != f_roe_q[1], f_roe_q[1], 0)
// When auto_fetch=true, fall back to na (not 0.0) if the API has no data,
// so the 'data missing' table state shows correctly.
float roe_q_val          = not na(f_roe_q) ? f_roe_q : (auto_fetch ? na : roe_q)
float roe_q_prev_val     = not na(roe_q_prev_fetched) ? roe_q_prev_fetched : (auto_fetch ? na : roe_q_prev)

float f_netprofit_q            = auto_fetch ? request.financial(syminfo.tickerid, "net_income", "FQ") : na
float netprofit_q_prev_fetched = ta.valuewhen(not na(f_netprofit_q) and not na(f_netprofit_q[1]) and f_netprofit_q != f_netprofit_q[1], f_netprofit_q[1], 0)
float netprofit_q_val          = not na(f_netprofit_q) ? f_netprofit_q : (auto_fetch ? na : netprofit_q)
float netprofit_q_prev_val     = not na(netprofit_q_prev_fetched) ? netprofit_q_prev_fetched : (auto_fetch ? na : netprofit_q_prev)

float f_revenue_q            = auto_fetch ? request.financial(syminfo.tickerid, "total_revenue", "FQ") : na
float revenue_q_prev_fetched = ta.valuewhen(not na(f_revenue_q) and not na(f_revenue_q[1]) and f_revenue_q != f_revenue_q[1], f_revenue_q[1], 0)
float revenue_q_val          = not na(f_revenue_q) ? f_revenue_q : (auto_fetch ? na : revenue_q)
float revenue_q_prev_val     = not na(revenue_q_prev_fetched) ? revenue_q_prev_fetched : (auto_fetch ? na : revenue_q_prev)

float f_ebitda_q            = auto_fetch ? request.financial(syminfo.tickerid, "ebitda", "FQ") : na
float ebitda_q_prev_fetched = ta.valuewhen(not na(f_ebitda_q) and not na(f_ebitda_q[1]) and f_ebitda_q != f_ebitda_q[1], f_ebitda_q[1], 0)
float ebitda_q_val          = not na(f_ebitda_q) ? f_ebitda_q : (auto_fetch ? na : ebitda_q)
float ebitda_q_prev_val     = not na(ebitda_q_prev_fetched) ? ebitda_q_prev_fetched : (auto_fetch ? na : ebitda_q_prev)
// Annual EBITDA fetched separately for use in Net Debt/EBITDA (c12)
float f_ebitda_fy           = auto_fetch ? request.financial(syminfo.tickerid, "ebitda", "FY") : na

float f_operprofit_q            = auto_fetch ? request.financial(syminfo.tickerid, "operating_income", "FQ") : na
float operprofit_q_prev_fetched = ta.valuewhen(not na(f_operprofit_q) and not na(f_operprofit_q[1]) and f_operprofit_q != f_operprofit_q[1], f_operprofit_q[1], 0)
float operprofit_q_val          = not na(f_operprofit_q) ? f_operprofit_q : (auto_fetch ? na : operprofit_q)
float operprofit_q_prev_val     = not na(operprofit_q_prev_fetched) ? operprofit_q_prev_fetched : (auto_fetch ? na : operprofit_q_prev)

float f_eps_q            = auto_fetch ? request.financial(syminfo.tickerid, "earnings_per_share_basic", "FQ") : na
float eps_q_prev_fetched = ta.valuewhen(not na(f_eps_q) and not na(f_eps_q[1]) and f_eps_q != f_eps_q[1], f_eps_q[1], 0)
float eps_q_val          = not na(f_eps_q) ? f_eps_q : (auto_fetch ? na : eps_q)
float eps_q_prev_val     = not na(eps_q_prev_fetched) ? eps_q_prev_fetched : (auto_fetch ? na : eps_q_prev)

// Other fields (try annual/TTM where appropriate)
float f_free_float       = auto_fetch ? request.financial(syminfo.tickerid, "float_shares_percent", "FY") : na
float free_float_val     = not na(f_free_float) ? f_free_float : (auto_fetch ? na : free_float)

float f_peg              = auto_fetch ? request.financial(syminfo.tickerid, "price_earnings_to_growth_ttm", "TTM") : na
float peg_ratio_val      = not na(f_peg) ? f_peg : (auto_fetch ? na : peg_ratio)

// 'net_income_growth' is not a documented TradingView field and silently returns na.
// Compute annual earnings growth directly from annual net income instead.
float f_netincome_fy      = auto_fetch ? request.financial(syminfo.tickerid, "net_income", "FY") : na
float f_netincome_fy_prev = ta.valuewhen(not na(f_netincome_fy) and not na(f_netincome_fy[1]) and f_netincome_fy != f_netincome_fy[1], f_netincome_fy[1], 0)
float f_earnings_growth   = not na(f_netincome_fy) and not na(f_netincome_fy_prev) and f_netincome_fy_prev != 0 ? (f_netincome_fy - f_netincome_fy_prev) / math.abs(f_netincome_fy_prev) * 100 : na
float earnings_growth_val = not na(f_earnings_growth) ? f_earnings_growth : (auto_fetch ? na : earnings_growth)

float f_current_assets   = auto_fetch ? request.financial(syminfo.tickerid, "total_current_assets", "FQ") : na
float current_assets_val = not na(f_current_assets) ? f_current_assets : (auto_fetch ? na : current_assets)

float f_current_liab     = auto_fetch ? request.financial(syminfo.tickerid, "total_current_liabilities", "FQ") : na
float current_liab_val   = not na(f_current_liab) ? f_current_liab : (auto_fetch ? na : current_liab)

float f_total_debt       = auto_fetch ? request.financial(syminfo.tickerid, "total_debt", "FQ") : na
float total_debt_val     = not na(f_total_debt) ? f_total_debt : (auto_fetch ? na : total_debt)

float f_cash_equiv       = auto_fetch ? request.financial(syminfo.tickerid, "cash_and_equivalents", "FQ") : na
float cash_equiv_val     = not na(f_cash_equiv) ? f_cash_equiv : (auto_fetch ? na : cash_equiv)

float f_inventory        = auto_fetch ? request.financial(syminfo.tickerid, "inventory", "FQ") : na
float inventory_val      = not na(f_inventory) ? f_inventory : (auto_fetch ? na : inventory)

float f_opcf_current_y    = auto_fetch ? request.financial(syminfo.tickerid, "cash_from_operations_annual", "FY") : na
float opcf_prev_y_fetched = ta.valuewhen(not na(f_opcf_current_y) and not na(f_opcf_current_y[1]) and f_opcf_current_y != f_opcf_current_y[1], f_opcf_current_y[1], 0)
float opcf_current_y_val  = not na(f_opcf_current_y) ? f_opcf_current_y : (auto_fetch ? na : opcf_current_y)
float opcf_prev_y_val     = not na(opcf_prev_y_fetched) ? opcf_prev_y_fetched : (auto_fetch ? na : opcf_prev_y)


// Criterion checks (booleans). Any `na` inputs cause the specific check
// to evaluate to `false` (conservative default). Users can replace inputs
// with platform-fetched fields when available.

// 1 — Star Market Listing
c1 = str.upper(market_segment) == "YILDIZ" or str.upper(market_segment) == "YLDIZ"

// 2 — Quarterly Increasing ROE
c2 = not na(roe_q_val) and not na(roe_q_prev_val) and (roe_q_val > roe_q_prev_val)

// 3 — Quarterly Increasing Net Profit
c3 = not na(netprofit_q_val) and not na(netprofit_q_prev_val) and (netprofit_q_val > netprofit_q_prev_val)

// 4 — Quarterly Increasing Revenue
c4 = not na(revenue_q_val) and not na(revenue_q_prev_val) and (revenue_q_val > revenue_q_prev_val)

// 5 — Quarterly Increasing EBITDA
c5 = not na(ebitda_q_val) and not na(ebitda_q_prev_val) and (ebitda_q_val > ebitda_q_prev_val)

// 6 — Quarterly Increasing EBITDA Margin
ebitda_margin_q      = not na(ebitda_q_val) and not na(revenue_q_val) and (revenue_q_val != 0) ? ebitda_q_val / revenue_q_val : na
ebitda_margin_q_prev = not na(ebitda_q_prev_val) and not na(revenue_q_prev_val) and (revenue_q_prev_val != 0) ? ebitda_q_prev_val / revenue_q_prev_val : na
c6 = not na(ebitda_margin_q) and not na(ebitda_margin_q_prev) and (ebitda_margin_q > ebitda_margin_q_prev)

// 7 — Quarterly Increasing Operating Profit
c7 = not na(operprofit_q_val) and not na(operprofit_q_prev_val) and (operprofit_q_val > operprofit_q_prev_val)

// 8 — Quarterly Increasing EPS
c8 = not na(eps_q_val) and not na(eps_q_prev_val) and (eps_q_val > eps_q_prev_val)

// 9 — Free Float Rate Below 70%
c9 = not na(free_float_val) and (free_float_val < 0.70)

// 10 — PEG Ratio Below 1 (only when earnings growth > 0)
c10 = not na(peg_ratio_val) and not na(earnings_growth_val) and (earnings_growth_val > 0) and (peg_ratio_val < 1.0)

// 11 — Current Ratio Between 1 and 3
curr_ratio = not na(current_assets_val) and not na(current_liab_val) and (current_liab_val != 0) ? current_assets_val / current_liab_val : na
c11 = not na(curr_ratio) and (curr_ratio >= 1.0) and (curr_ratio <= 3.0)

// 12 — Net Debt / EBITDA Below 3
net_debt = not na(total_debt_val) and not na(cash_equiv_val) ? (total_debt_val - cash_equiv_val) : na
// Prefer fetched annual EBITDA; fall back to quarterly * 4 as a rough estimate only
ebitda_annual = not na(f_ebitda_fy) ? f_ebitda_fy : (not na(ebitda_q_val) ? ebitda_q_val * 4.0 : na)
c12 = false
if not na(net_debt)
    if not na(ebitda_annual) and (ebitda_annual > 0)
        c12 := (net_debt / ebitda_annual) < 3.0
    else
        // Negative net debt (more cash than debt) passes automatically
        c12 := net_debt < 0

// 13 — Cash Ratio Above 0.2
cash_ratio = not na(cash_equiv_val) and not na(current_liab_val) and (current_liab_val != 0) ? cash_equiv_val / current_liab_val : na
c13 = not na(cash_ratio) and (cash_ratio > 0.20)

// 14 — Quick Ratio Between 0.5 and 2
quick_ratio = not na(current_assets_val) and not na(inventory_val) and not na(current_liab_val) and (current_liab_val != 0) ? (current_assets_val - inventory_val) / current_liab_val : na
c14 = not na(quick_ratio) and (quick_ratio >= 0.5) and (quick_ratio <= 2.0)

// 15 — Positive Year-over-Year Operating Cash Flow Growth
c15 = not na(opcf_current_y_val) and not na(opcf_prev_y_val) and (opcf_current_y_val > opcf_prev_y_val)

// Overall result: require all criteria to be true
all_pass = c1 and c2 and c3 and c4 and c5 and c6 and c7 and c8 and c9 and c10 and c11 and c12 and c13 and c14 and c15

// Helper functions for the results table.
// cellText: "✔" pass | "✖" fail | "—" data missing
// cellColor: green   | red       | gray
cellText(bool pass, bool dataOk) =>
    dataOk ? (pass ? "✔" : "✖") : "—"
cellColor(bool pass, bool dataOk) =>
    dataOk ? (pass ? color.green : color.red) : color.gray

// --- Visualization ---
// One-line status on the chart: PASS/FAIL
var label statusLbl = na
if barstate.islast
    statusText = all_pass ? "PASS: All 15 criteria" : "FAIL"
    labelColor = all_pass ? color.new(color.green, 0) : color.new(color.red, 0)
    if not na(statusLbl)
        label.delete(statusLbl)
    statusLbl := label.new(bar_index, close, statusText, color=labelColor, textcolor=color.white, style=label.style_label_down, yloc=yloc.price)

// Table showing each criterion and its boolean result (only on final bar)
var table t = table.new(position.top_right, 2, 16, border_width=1)
if barstate.islast
    // Header
    table.cell(t, 0, 0, "Criterion", text_color=color.white, bgcolor=color.new(color.blue, 10))
    table.cell(t, 1, 0, "Pass", text_color=color.white, bgcolor=color.new(color.blue, 10))

    // Rows (1..15)
    table.cell(t, 0, 1, "1 — Star Market")
    table.cell(t, 1, 1, cellText(c1, true), text_color=cellColor(c1, true))

    bool d2 = not na(roe_q_val) and not na(roe_q_prev_val)
    table.cell(t, 0, 2, "2 — ROE ↑ q/q")
    table.cell(t, 1, 2, cellText(c2, d2), text_color=cellColor(c2, d2))

    bool d3 = not na(netprofit_q_val) and not na(netprofit_q_prev_val)
    table.cell(t, 0, 3, "3 — Net Profit ↑ q/q")
    table.cell(t, 1, 3, cellText(c3, d3), text_color=cellColor(c3, d3))

    bool d4 = not na(revenue_q_val) and not na(revenue_q_prev_val)
    table.cell(t, 0, 4, "4 — Revenue ↑ q/q")
    table.cell(t, 1, 4, cellText(c4, d4), text_color=cellColor(c4, d4))

    bool d5 = not na(ebitda_q_val) and not na(ebitda_q_prev_val)
    table.cell(t, 0, 5, "5 — EBITDA ↑ q/q")
    table.cell(t, 1, 5, cellText(c5, d5), text_color=cellColor(c5, d5))

    bool d6 = d5 and d4
    table.cell(t, 0, 6, "6 — EBITDA Margin ↑ q/q")
    table.cell(t, 1, 6, cellText(c6, d6), text_color=cellColor(c6, d6))

    bool d7 = not na(operprofit_q_val) and not na(operprofit_q_prev_val)
    table.cell(t, 0, 7, "7 — Operating Profit ↑ q/q")
    table.cell(t, 1, 7, cellText(c7, d7), text_color=cellColor(c7, d7))

    bool d8 = not na(eps_q_val) and not na(eps_q_prev_val)
    table.cell(t, 0, 8, "8 — EPS ↑ q/q")
    table.cell(t, 1, 8, cellText(c8, d8), text_color=cellColor(c8, d8))

    bool d9 = not na(free_float_val)
    table.cell(t, 0, 9, "9 — Free Float < 70%")
    table.cell(t, 1, 9, cellText(c9, d9), text_color=cellColor(c9, d9))

    bool d10 = not na(peg_ratio_val) and not na(earnings_growth_val)
    table.cell(t, 0, 10, "10 — PEG < 1 (growth>0)")
    table.cell(t, 1, 10, cellText(c10, d10), text_color=cellColor(c10, d10))

    bool d11 = not na(current_assets_val) and not na(current_liab_val)
    table.cell(t, 0, 11, "11 — Current Ratio 1..3")
    table.cell(t, 1, 11, cellText(c11, d11), text_color=cellColor(c11, d11))

    bool d12 = not na(total_debt_val) and not na(cash_equiv_val) and not na(ebitda_annual)
    table.cell(t, 0, 12, "12 — Net Debt / EBITDA < 3")
    table.cell(t, 1, 12, cellText(c12, d12), text_color=cellColor(c12, d12))

    bool d13 = not na(cash_equiv_val) and not na(current_liab_val)
    table.cell(t, 0, 13, "13 — Cash Ratio > 0.2")
    table.cell(t, 1, 13, cellText(c13, d13), text_color=cellColor(c13, d13))

    bool d14 = not na(current_assets_val) and not na(inventory_val) and not na(current_liab_val)
    table.cell(t, 0, 14, "14 — Quick Ratio 0.5..2")
    table.cell(t, 1, 14, cellText(c14, d14), text_color=cellColor(c14, d14))

    bool d15 = not na(opcf_current_y_val) and not na(opcf_prev_y_val)
    table.cell(t, 0, 15, "15 — OCF YoY > 0")
    table.cell(t, 1, 15, cellText(c15, d15), text_color=cellColor(c15, d15))

// End of screener
