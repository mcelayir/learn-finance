# .gitignore for learn-finance
# Repo mainly contains Markdown, Python and Pine script files.

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/
venv.bak/

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.coverage
.coverage.*
.cache
.pytest_cache/
htmlcov/

# Sphinx / docs build outputs
docs/_build/
_build/
site/
_site/

# Editor & IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Env / secrets
.env
.env.local
.env.*
secrets.json

# Logs and databases
*.log
*.sqlite3
*.db

# Type checkers / caches
.mypy_cache/
.python-version

# Node (if present)
node_modules/

# Misc
*.tmp
*.bak
*.orig
